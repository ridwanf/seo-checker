{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@seo-checker/shared-types": [
        "packages/shared-types/src"
      ],
      "@seo-checker/seo-engine": [
        "packages/seo-engine/src"
      ]
    },
    "strict": true,

    "skipLibCheck": true,

    "esModuleInterop": true,

    "resolveJsonModule": true
  }
}